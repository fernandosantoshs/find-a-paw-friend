generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ong {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  whatsapp           String   @unique
  zipcode            String
  address_street     String
  address_number     String
  address_complement String?
  city               String
  uf                 String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  pets               pet[]

  @@map("ongs")
}

model pet {
  id                 String   @id @default(uuid())
  name               String
  estimated_birthday DateTime
  description        String
  image              String
  ongId              String
  ong                Ong      @relation(fields: [ongId], references: [id])
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("pets")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("users")
}
